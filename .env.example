OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=replace_with_your_ollama_cloud_api_key
RECURSIVE_HARNESS_MODEL=gemma4:31b
RECURSIVE_HARNESS_TEMPERATURE=1
RECURSIVE_HARNESS_TOP_P=0.95
RECURSIVE_HARNESS_TOP_K=64

# Optional: require bearer auth for this harness runtime's /v1/* routes.
RECURSIVE_HARNESS_API_KEY=replace_with_your_product_runtime_key

# Optional local worker that lets the cloud/runtime queue work for this computer while it is on.
RECURSIVE_RUNTIME_URL=http://localhost:4317
RECURSIVE_LOCAL_WORKER_ID=my-windows-pc
RECURSIVE_LOCAL_WORKER_NAME=Lenovo local worker
RECURSIVE_LOCAL_WORKER_INTERVAL_MS=30000
RECURSIVE_LOCAL_TASK_TIMEOUT_MS=120000
RECURSIVE_LOCAL_WORKER_ONCE=0
